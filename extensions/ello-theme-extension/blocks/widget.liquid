{% schema %}
{
  "name": "Ello Virtual Try-On",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "backend_url",
      "label": "Backend URL",
      "default": "https://ello-vto-staging-13593516897.us-central1.run.app",
      "info": "Ello backend URL — auto-set on install, do not change unless instructed."
    }
  ]
}
{% endschema %}

<!-- Ello Virtual Try-On Widget (Injected via Theme Extension) -->

<!-- Warm DNS + TLS connections in parallel with HTML parsing so the first
     widget asset request doesn't pay handshake latency. crossorigin is
     required for preconnects that will be used for fetch/CORS requests. -->
<link rel="preconnect" href="{{ block.settings.backend_url }}" crossorigin>
<link rel="preconnect" href="https://rwmvgwnebnsqcyhhurti.supabase.co" crossorigin>
<link rel="dns-prefetch" href="{{ block.settings.backend_url }}">
<link rel="dns-prefetch" href="https://rwmvgwnebnsqcyhhurti.supabase.co">

<script
  src="{{ block.settings.backend_url }}/widget-loader.js"
  data-shop="{{ shop.permanent_domain }}"
  defer
></script>

<script>
  console.log("Ello Widget Loaded via Extension for: {{ shop.permanent_domain }}");
</script>
